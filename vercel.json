{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/auth/login", "destination": "/pages/auth/login.html" },
    { "source": "/auth/register", "destination": "/pages/auth/register.html" },
    { "source": "/customer/profile", "destination": "/pages/customer/profile.html" },
    { "source": "/customer/edit-profile", "destination": "/pages/customer/edit-profile.html" },
    { "source": "/community/forum", "destination": "/pages/community/forum.html" },
    { "source": "/community/thread-detail", "destination": "/pages/community/thread-detail.html" },
    { "source": "/directory/home", "destination": "/pages/directory/home.html" },
    { "source": "/directory/explore", "destination": "/pages/directory/explore.html" },
    { "source": "/directory/vendor-detail", "destination": "/pages/directory/vendor-detail.html" },
    { "source": "/vendor/dashboard", "destination": "/pages/vendor/dashboard.html" },
    { "source": "/admin/super-admin", "destination": "/pages/admin/super-admin.html" },
    { "source": "/privacy-policy", "destination": "/pages/privacy-policy.html" },
    { "source": "/terms-of-service", "destination": "/pages/terms-of-service.html" }
  ],
  "routes": [
    { "src": "^/(.+)$", "dest": "/pages/404.html", "status": 404 }
  ]
}

